{
  "name": "lan-sync-browser",
  "version": "1.0.0",
  "description": "LAN-Native Synchronized Browser Platform",
  "main": "main.js",
  "scripts": {
    "start": "node start.js",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.lanbrowser.desktop",
    "productName": "LAN Browser",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "express": "^5.2.1",
    "local-ip-url": "^1.0.10",
    "qrcode": "^1.5.4",
    "uuid": "^9.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  }
}